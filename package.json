{
  "name": "crackitt-platform",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "migrate": "pnpm --filter api migrate",
    "seed": "pnpm --filter api seed",
    "db:setup": "pnpm migrate && pnpm seed"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.2",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
